{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kh",
  "scopeName": "source.kh",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#functionDecl"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.kh",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kh",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.kh"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.kh"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.kh",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.kh",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.kh"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.kh"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.kh",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kh",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kh",
          "match": "\\b(bool|break|byte|case|char|char16|char32|const|continue|define|default|deinit|double|else|enum|false|float|for|import|if|int8|int16|int32|int64|int128|init|interface|long|module|namespace|null|otherwise|return|repeat|short|static|struct|switch|string|syscall|true|type|union|uint8|uint16|uint32|uint64|uint128|void|while)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kh",
          "match": "==|!=|<=|>=|[=+\\-*/<>]"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.kh",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.kh",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}